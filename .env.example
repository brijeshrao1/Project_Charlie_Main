# ============================================================
# Project Charlie — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.
# ============================================================


# ── Application ─────────────────────────────────────────────
# Set to "production" on servers; "development" locally.
APP_ENV=development

# Comma-separated list of allowed CORS origins.
# In production, list only your real domain(s).
ALLOWED_ORIGINS=http://localhost


# ── Oracle credentials (optional) ───────────────────────────
ORACLE_USERNAME=
ORACLE_PASSWORD=
ORACLE_ENV=


# ── Clerk authentication (optional) ─────────────────────────
# Set CLERK_JWT_REQUIRED=true to enforce JWT validation.
CLERK_JWT_REQUIRED=false
CLERK_ISSUER=
CLERK_AUDIENCE=
CLERK_API_KEY=

# Frontend — baked into the React bundle at build time
REACT_APP_CLERK_PUBLISHABLE_KEY=
REACT_APP_CLERK_JWT_TEMPLATE=charlie tool


# ── Gemini / GenAI (optional) ────────────────────────────────
# Required by both the backend and the NLP service.
GEMINI_API_KEY=


# ── NLP service (Ollama) ─────────────────────────────────────
# Host where Ollama is running (Docker default shown).
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=mistral
