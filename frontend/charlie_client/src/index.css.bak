* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

/* ============================================
   SKEUOMORPHISM THEME - CHARLIE UI
   ============================================ */

:root {
  /* Primary Colors - Warm & Professional */
  --primary: #2c3e50;
  --primary-light: #34495e;
  --primary-dark: #1a252f;
  
  /* Accent Colors */
  --accent: #e74c3c;
  --accent-light: #ec7063;
  --accent-dark: #c0392b;
  
  /* Neutral Colors - Cream for skeuomorphism */
  --bg-cream: #f5f3f0;
  --bg-light: #f9f7f3;
  --bg-paper: #faf8f5;
  
  /* Text Colors */
  --text-primary: #1a1a1a;
  --text-secondary: #555555;
  --text-light: #888888;
  
  /* Status Colors */
  --success: #27ae60;
  --warning: #f39c12;
  --error: #e74c3c;
  --info: #3498db;
  
  /* Shadow System (Skeuomorphic Depth) */
  --shadow-sm: 0 2px 4px rgba(0, 0, 0, 0.08), inset 1px 1px 0 rgba(255, 255, 255, 0.6);
  --shadow-md: 0 4px 8px rgba(0, 0, 0, 0.12), inset 1px 1px 0 rgba(255, 255, 255, 0.8);
  --shadow-lg: 0 8px 16px rgba(0, 0, 0, 0.15), inset 0 1px 0 rgba(255, 255, 255, 0.8);
  --shadow-xl: 0 12px 24px rgba(0, 0, 0, 0.2), inset 0 1px 0 rgba(255, 255, 255, 0.9);
  
  /* Spacing */
  --spacing-xs: 4px;
  --spacing-sm: 8px;
  --spacing-md: 16px;
  --spacing-lg: 24px;
  --spacing-xl: 32px;
  --spacing-2xl: 48px;
  
  /* Border Radius - Soft skeuomorphic corners */
  --radius-sm: 6px;
  --radius-md: 12px;
  --radius-lg: 18px;
  
  /* Transitions */
  --transition-fast: all 0.15s cubic-bezier(0.4, 0, 0.2, 1);
  --transition-base: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  --transition-slow: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  
  /* Font System */
  --font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Roboto", "Oxygen",
    "Ubuntu", "Cantarell", "Fira Sans", "Droid Sans", "Helvetica Neue",
    sans-serif;
  --font-size-xs: 12px;
  --font-size-sm: 14px;
  --font-size-base: 16px;
  --font-size-lg: 18px;
  --font-size-xl: 20px;
  --font-size-2xl: 24px;
  --font-size-3xl: 32px;
  
  /* Line Heights */
  --line-height-tight: 1.2;
  --line-height-base: 1.5;
  --line-height-relaxed: 1.75;
}

/* ============================================
   BASE STYLES
   ============================================ */

html, body {
  font-family: var(--font-family);
  font-size: var(--font-size-base);
  color: var(--text-primary);
  background-color: var(--bg-cream);
  line-height: var(--line-height-base);
  height: 100%;
  overflow: hidden;
}

body {
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

#root {
  height: 100%;
  overflow: hidden;
}

/* ============================================
   LAYOUT COMPONENTS
   ============================================ */

.layout {
  display: flex;
  height: 100vh;
  overflow: hidden;
  background-color: var(--bg-cream);
}

.main-container {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.content-wrapper {
  flex: 1;
  overflow-y: auto;
  padding: var(--spacing-lg);
  background: linear-gradient(135deg, var(--bg-cream) 0%, var(--bg-light) 100%);
}

/* ============================================
   SKEUOMORPHIC CARDS & SURFACES
   ============================================ */

.card {
  background: var(--bg-paper);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-md);
  padding: var(--spacing-md);
  border: 1px solid rgba(255, 255, 255, 0.8);
  transition: var(--transition-base);
  position: relative;
}

.card:hover {
  box-shadow: var(--shadow-lg);
  transform: translateY(-2px);
}

.card-elevated {
  background: linear-gradient(135deg, var(--bg-paper) 0%, #f8f6f3 100%);
  box-shadow: var(--shadow-lg);
}

.card-clickable {
  cursor: pointer;
}

.card-clickable:active {
  box-shadow: var(--shadow-sm);
  transform: translateY(1px);
}

/* ============================================
   BUTTONS - SKEUOMORPHIC DEPTH
   ============================================ */

button, .btn {
  font-family: var(--font-family);
  font-size: var(--font-size-sm);
  font-weight: 600;
  padding: var(--spacing-sm) var(--spacing-md);
  border: none;
  border-radius: var(--radius-sm);
  cursor: pointer;
  transition: var(--transition-fast);
  position: relative;
  outline: none;
  border: 1px solid rgba(0, 0, 0, 0.1);
}

/* Primary Button */
.btn-primary {
  background: linear-gradient(135deg, var(--accent) 0%, var(--accent-dark) 100%);
  color: white;
  box-shadow: 0 4px 8px rgba(231, 76, 60, 0.3), inset 0 1px 0 rgba(255, 255, 255, 0.3);
}

.btn-primary:hover {
  box-shadow: 0 6px 12px rgba(231, 76, 60, 0.4), inset 0 1px 0 rgba(255, 255, 255, 0.5);
  transform: translateY(-2px);
}

.btn-primary:active {
  box-shadow: inset 0 2px 4px rgba(0, 0, 0, 0.2), inset 0 1px 0 rgba(255, 255, 255, 0.2);
  transform: translateY(0);
}

/* Secondary Button */
.btn-secondary {
  background: linear-gradient(135deg, var(--bg-paper) 0%, #f0ede8 100%);
  color: var(--text-primary);
  box-shadow: var(--shadow-md);
}

.btn-secondary:hover {
  box-shadow: var(--shadow-lg);
  transform: translateY(-2px);
}

.btn-secondary:active {
  box-shadow: var(--shadow-sm);
  transform: translateY(0);
}

/* Success Button */
.btn-success {
  background: linear-gradient(135deg, var(--success) 0%, #229954 100%);
  color: white;
  box-shadow: 0 4px 8px rgba(39, 174, 96, 0.3), inset 0 1px 0 rgba(255, 255, 255, 0.3);
}

.btn-success:hover {
  box-shadow: 0 6px 12px rgba(39, 174, 96, 0.4), inset 0 1px 0 rgba(255, 255, 255, 0.5);
  transform: translateY(-2px);
}

/* Small Button */
.btn-sm {
  padding: var(--spacing-xs) var(--spacing-sm);
  font-size: var(--font-size-xs);
}

/* Large Button */
.btn-lg {
  padding: var(--spacing-md) var(--spacing-lg);
  font-size: var(--font-size-lg);
}

/* ============================================
   INPUT FIELDS - SKEUOMORPHIC
   ============================================ */

input, textarea, select {
  font-family: var(--font-family);
  font-size: var(--font-size-base);
  padding: var(--spacing-sm) var(--spacing-md);
  border: 1px solid #d0ccc8;
  border-radius: var(--radius-sm);
  background: var(--bg-light);
  color: var(--text-primary);
  transition: var(--transition-fast);
  box-shadow: inset 0 1px 3px rgba(0, 0, 0, 0.05), inset 0 1px 0 rgba(255, 255, 255, 0.8);
}

input:focus, textarea:focus, select:focus {
  outline: none;
  border-color: var(--accent);
  background: white;
  box-shadow: inset 0 1px 3px rgba(0, 0, 0, 0.05), 0 0 8px rgba(231, 76, 60, 0.3);
}

textarea {
  resize: vertical;
  min-height: 100px;
}

/* ============================================
   FORM GROUPS
   ============================================ */

.form-group {
  margin-bottom: var(--spacing-md);
}

.form-label {
  display: block;
  margin-bottom: var(--spacing-sm);
  font-weight: 600;
  color: var(--text-primary);
  font-size: var(--font-size-sm);
  letter-spacing: 0.3px;
}

.form-helper {
  font-size: var(--font-size-xs);
  color: var(--text-light);
  margin-top: var(--spacing-xs);
}

/* ============================================
   TYPOGRAPHY
   ============================================ */

h1, h2, h3, h4, h5, h6 {
  font-weight: 700;
  line-height: var(--line-height-tight);
  color: var(--text-primary);
  margin-bottom: var(--spacing-sm);
}

h1 {
  font-size: var(--font-size-3xl);
  letter-spacing: -1px;
}

h2 {
  font-size: var(--font-size-2xl);
  letter-spacing: -0.5px;
}

h3 {
  font-size: var(--font-size-xl);
}

h4 {
  font-size: var(--font-size-lg);
}

p {
  margin-bottom: var(--spacing-md);
  line-height: var(--line-height-relaxed);
}

a {
  color: var(--accent);
  text-decoration: none;
  transition: var(--transition-fast);
  font-weight: 500;
}

a:hover {
  color: var(--accent-dark);
  text-decoration: underline;
}

/* ============================================
   TABLES
   ============================================ */

table {
  width: 100%;
  border-collapse: collapse;
}

thead {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
  color: white;
}

th {
  padding: var(--spacing-md);
  text-align: left;
  font-weight: 600;
  letter-spacing: 0.5px;
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.3);
}

td {
  padding: var(--spacing-md);
  border-bottom: 1px solid #e8e5e0;
  background: var(--bg-paper);
}

tbody tr:hover {
  background: #f5f3f0;
}

tbody tr:nth-child(even) {
  background: #fdfbf8;
}

/* ============================================
   ALERTS & STATUS
   ============================================ */

.alert {
  padding: var(--spacing-md) var(--spacing-lg);
  border-radius: var(--radius-md);
  margin-bottom: var(--spacing-md);
  border-left: 4px solid;
  box-shadow: var(--shadow-sm);
}

.alert-success {
  background: #d5f4e6;
  border-left-color: var(--success);
  color: #165b33;
}

.alert-error {
  background: #fadbd8;
  border-left-color: var(--error);
  color: #78281f;
}

.alert-warning {
  background: #fdeaa8;
  border-left-color: var(--warning);
  color: #7d6608;
}

.alert-info {
  background: #d6eaf8;
  border-left-color: var(--info);
  color: #154360;
}

/* ============================================
   LOADING & SPINNERS
   ============================================ */

.spinner {
  display: inline-block;
  width: 40px;
  height: 40px;
  border: 4px solid var(--bg-cream);
  border-top-color: var(--accent);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.pulse {
  animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
}

@keyframes pulse {
  0%, 100% {
    opacity: 1;
  }
  50% {
    opacity: 0.5;
  }
}

/* ============================================
   UTILITY CLASSES
   ============================================ */

.center-screen {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100vh;
  flex-direction: column;
  background: linear-gradient(135deg, var(--bg-cream) 0%, var(--bg-light) 100%);
}

.text-center {
  text-align: center;
}

.mt-1 { margin-top: var(--spacing-sm); }
.mt-2 { margin-top: var(--spacing-md); }
.mt-3 { margin-top: var(--spacing-lg); }
.mb-1 { margin-bottom: var(--spacing-sm); }
.mb-2 { margin-bottom: var(--spacing-md); }
.mb-3 { margin-bottom: var(--spacing-lg); }
.p-1 { padding: var(--spacing-sm); }
.p-2 { padding: var(--spacing-md); }
.p-3 { padding: var(--spacing-lg); }

.text-muted {
  color: var(--text-light);
}

.text-success {
  color: var(--success);
}

.text-error {
  color: var(--error);
}

.text-warning {
  color: var(--warning);
}

.opacity-50 {
  opacity: 0.5;
}

.opacity-75 {
  opacity: 0.75;
}

/* ============================================
   SCROLLBAR STYLING
   ============================================ */

::-webkit-scrollbar {
  width: 10px;
  height: 10px;
}

::-webkit-scrollbar-track {
  background: var(--bg-cream);
}

::-webkit-scrollbar-thumb {
  background: #d0ccc8;
  border-radius: 5px;
}

::-webkit-scrollbar-thumb:hover {
  background: #a8a398;
}

/* ============================================
   RESPONSIVE DESIGN
   ============================================ */

@media (max-width: 1024px) {
  .layout {
    flex-direction: column;
  }
  
  .content-wrapper {
    padding: var(--spacing-md);
  }
}

@media (max-width: 768px) {
  :root {
    --spacing-md: 12px;
    --spacing-lg: 16px;
  }
  
  .card {
    padding: var(--spacing-sm);
  }
  
  button, .btn {
    padding: var(--spacing-sm) var(--spacing-md);
  }
}
